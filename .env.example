# --- Fyers (fyers.in) — RECOMMENDED: free data + order APIs ---
# Create an app at https://myapi.fyers.in -> App Id looks like AB12345-100.
# Then run once:  python -m bot.fyers_auth   (interactive login; tokens are
# cached and auto-renewed daily using FYERS_PIN + the refresh token).
FYERS_APP_ID=
FYERS_SECRET_ID=
FYERS_PIN=
# Only change if your app uses a custom redirect:
# FYERS_REDIRECT_URI=

# --- Dhan (dhan.co) DhanHQ v2 API (alternative broker) ---
# Data feed requires the paid Data API subscription (Rs.499+GST/mo);
# order APIs are free. Token valid 24h — regenerate daily on web.dhan.co.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# --- Live trading confirmation (gate 2 of 4) ---
# The bot will NEVER place a real order unless this is set to the exact string
# YES-I-UNDERSTAND-REAL-MONEY *and* config.LIVE_TRADING_ENABLED=True *and*
# the strategy is in config.LIVE_STRATEGY_ALLOWLIST *and* run_live.py is
# launched with --live. Leave blank for paper trading.
LIVE_CONFIRM=

# --- Discord alerts (optional; leave blank to disable) ---
DISCORD_WEBHOOK_URL=
